# Для production задайте в .env или export перед docker compose up
# JWT_SECRET=your-secret
# NUXT_PUBLIC_API_BASE=https://ivanovo.online
# Админка: тот же хост, что в браузере (nginx проксирует /api/ на backend) — без CORS
# VITE_API_BASE_URL=https://admin.ivanovo.online
# CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
# MinIO/S3: публичный адрес картинок для сайта (nginx может проксировать /news-aggregator/ → :9000)
# S3_PUBLIC_BASE_URL=https://ivanovo.online/news-aggregator
# ADMIN_PORT не используется: порт админки назначается автоматически (docker compose port admin 80)
