DATABASE_URL="postgresql://user:password@localhost:5432/news_aggregator?schema=public"
PORT=3000
# Required in production. In development a default is used if unset.
JWT_SECRET=change-me-in-production
# Comma-separated allowed origins (e.g. http://localhost:3001,http://localhost:5174). Leave empty in dev to allow all.
CORS_ORIGINS=
REDIS_URL=redis://localhost:6379
AI_PROVIDER=openai
OPENAI_API_KEY=
ZAI_API_KEY=

# Optional: S3-compatible storage (e.g. MinIO in Docker or AWS S3).
# If set, uploads can be stored in object storage instead of backend/uploads.
# MinIO (Docker): use S3_ENDPOINT and MINIO_ROOT_* as AWS_* keys.
# AWS: omit S3_ENDPOINT, set AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, S3_BUCKET, S3_REGION.
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_BASE_URL=           # Public URL for image links (e.g. http://localhost:9000/news-aggregator)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
